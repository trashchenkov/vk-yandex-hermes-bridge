# Yandex Message Queue for Cloud Function and VM worker
QUEUE_URL=https://message-queue.api.cloud.yandex.net/...
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ru-central1
QUEUE_ENDPOINT=https://message-queue.api.cloud.yandex.net

# VK Callback/API
VK_GROUP_ID=123456789
VK_CONFIRMATION_TOKEN=...
VK_SECRET=...
VK_GROUP_TOKEN=...
VK_API_VERSION=5.199

# Access control. Keep production private by default.
# Comma-separated VK user ids that may reach Hermes tools.
VK_ALLOWED_USERS=123456789
# Development only. Do not enable for public communities.
VK_ALLOW_ALL_USERS=false
# Optional: reply to unauthorized users instead of silently ignoring them.
VK_UNAUTHORIZED_REPLY=Бот приватный. Доступ к Hermes Agent ограничен.

# Hermes API Server on the VM
HERMES_API_BASE=http://127.0.0.1:8642
# Optional; if omitted, worker reads API_SERVER_KEY from --hermes-env /root/.hermes/.env
HERMES_API_KEY=
HERMES_MODEL=hermes-agent
HERMES_TIMEOUT_MS=120000

# Worker tuning
LOG_LEVEL=INFO
DEDUP_DB=./state/vk-worker-dedup.sqlite3
QUEUE_MAX_MESSAGES=1
QUEUE_WAIT_TIME_SECONDS=20
QUEUE_VISIBILITY_TIMEOUT=300

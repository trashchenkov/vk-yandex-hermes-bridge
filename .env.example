# Yandex Message Queue for Cloud Function and VM worker
QUEUE_URL=https://message-queue.api.cloud.yandex.net/...
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ru-central1
QUEUE_ENDPOINT=https://message-queue.api.cloud.yandex.net

# VK Callback/API
VK_GROUP_ID=123456789
VK_CONFIRMATION_TOKEN=...
VK_SECRET=...
VK_GROUP_TOKEN=...
VK_API_VERSION=5.199

# Access control. Keep production private by default.
# VK_OWNER_ID is authoritative when set; VK_ALLOWED_USERS is the legacy owner allowlist fallback.
VK_OWNER_ID=123456789
VK_ALLOWED_USERS=123456789
# Comma-separated VK user ids that may reach Hermes but not owner-only commands.
VK_TRUSTED_USERS=
# Comma-separated VK user ids that are always denied, even if listed above.
VK_BLOCKED_USERS=
# Development only. Treat unknown users as trusted. Do not enable for public communities.
VK_ALLOW_ALL_USERS=false
# MVP public mode is deny-by-default; this only creates/reports handoff policy decisions.
VK_PUBLIC_HANDOFF=false
# Optional public FAQ/RAG-lite mode: point to markdown/txt community materials and use action=public_faq in VK_POLICY_JSON.
VK_PUBLIC_FAQ_PATHS=./docs
VK_PUBLIC_FAQ_MIN_SCORE=2
# Optional reply when public FAQ has no reliable source; empty means handoff/review only.
VK_PUBLIC_FAQ_MISS_REPLY=
# Optional explicit policy engine config. When set, VK_POLICY_JSON/VK_POLICY_FILE role ids override legacy allowlist envs.
# Example JSON: {"roles":{"owner":{"ids":["123"]},"trusted":{"ids":["456"]},"blocked":{"ids":[]}},"rules":{"public":{"action":"deny","hermes_allowed":false,"reason":"configured_public_deny"}}}
VK_POLICY_JSON=
VK_POLICY_FILE=
# Emergency brake: force deny for all non-owner traffic, including trusted users and public handoff.
VK_EMERGENCY_LOCKDOWN=false
# Optional: shadow mode calls Hermes for allowed users but sends proposed answers only to owner notification peer.
VK_SHADOW_MODE=false
# Optional: how to handle unauthorized users: ignore, reply, notify_owner, or reply_and_notify.
VK_UNAUTHORIZED_MODE=reply
# Required for notify_owner/reply_and_notify; defaults to first owner id if omitted.
VK_OWNER_PEER_ID=123456789
# Optional: reply to unauthorized users when mode includes reply.
VK_UNAUTHORIZED_REPLY=Бот приватный. Доступ к Hermes Agent ограничен.

# Hermes API Server on the VM
HERMES_API_BASE=http://127.0.0.1:8642
# Optional; if omitted, worker reads API_SERVER_KEY from --hermes-env /root/.hermes/.env
HERMES_API_KEY=
HERMES_MODEL=hermes-agent
# Optional separate Hermes API profile/settings for public Hermes replies (when policy uses public/group_chat reply with hermes_allowed=true).
HERMES_PUBLIC_PROFILE=vk-public
HERMES_PUBLIC_API_BASE=
HERMES_PUBLIC_API_KEY=
HERMES_PUBLIC_MODEL=
HERMES_PUBLIC_SESSION_PREFIX=vk-public
HERMES_TIMEOUT_MS=120000

# Worker tuning
LOG_LEVEL=INFO
# Optional: text or json. Use json for machine-parseable logs in production.
LOG_FORMAT=text
DEDUP_DB=./state/vk-worker-dedup.sqlite3
TRACE_DB=./state/vk-worker-trace.sqlite3
REVIEW_DB=./state/vk-worker-review.sqlite3
QUEUE_MAX_MESSAGES=1
QUEUE_WAIT_TIME_SECONDS=20
QUEUE_VISIBILITY_TIMEOUT=300
# VK Long Poll mode tuning (--long-poll, no Yandex Queue/Callback URL required).
VK_LONG_POLL_WAIT_SECONDS=25
VK_API_TIMEOUT_SECONDS=10
